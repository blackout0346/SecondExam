<Window x:Class="secondExam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:secondExam"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="900"
      
        >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition>
            </ColumnDefinition>
          
            
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions >
            <RowDefinition >
            </RowDefinition>
            <RowDefinition>
            </RowDefinition>
            <RowDefinition>
            </RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock Text="Продукция" FontSize="20" FontFamily="Segoe UI"  Grid.Row="0"  Background="#F4E8D3" ></TextBlock>
        <TextBlock Text="Поиск:" Grid.Row="0" FontSize="16" VerticalAlignment="Center" Margin="10" ></TextBlock>
        <TextBox x:Name="search" Grid.Row="0" Height="40" Width="300" Margin="70, 10" HorizontalAlignment="Left" TextChanged="search_TextChanged"  ></TextBox>
        <DataGrid x:Name="ProductTable" Grid.Row="1"></DataGrid>
        <StackPanel Grid.Row="2" Grid.Column="1"  Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left">
            <Button Width="100" Height="50" Margin="10" Foreground="White" Content="Добавить" Background="#67BA80" ></Button>
            <Button Width="100" Height="50" Margin="10" Foreground="White" Content="Изменить" Background="#67BA80"></Button>
            <Button Width="100" Height="50" Margin="10" Foreground="White" Content="Удалить" Background="#F1404A"></Button>
            <Button Width="100" Height="50" Margin="10" Foreground="White" Content="Назад" Background="#F1404A"></Button>
            <TextBlock x:Name="counts" Text="Всего записей" VerticalAlignment="Center"></TextBlock>
        </StackPanel>

    </Grid>
</Window>
