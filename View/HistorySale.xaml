<Window x:Class="secondExam.View.HistorySale"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:secondExam.View"
        mc:Ignorable="d"
        Title="HistorySale" Height="450" Width="800" Background="#F4E8D3">
    <Window.Resources>

        <Style TargetType="{x:Type TextBlock}"  >
            <Setter Property="FontFamily" Value="Segoe UI" ></Setter>
            <Setter Property="FontSize" Value="15" ></Setter>
        </Style>
        <Style TargetType="{x:Type Button}">
            <Setter Property="FontFamily" Value="Segoe UI"></Setter>
            <Setter Property="Width" Value="100"></Setter>
            <Setter Property="Height" Value="50"></Setter>
        </Style>
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="FontFamily" Value="Segoe UI"></Setter>
        </Style>


    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition>
            </ColumnDefinition>


        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions >
            <RowDefinition >
            </RowDefinition>
            <RowDefinition>
            </RowDefinition>
            <RowDefinition>
            </RowDefinition>
        </Grid.RowDefinitions>



        <TextBlock  Text="Мастер пол"  Grid.Row="0" Margin="30" HorizontalAlignment="Right" Padding="10,10,80,0"></TextBlock>
        <Image  Grid.Row="0"  Source="/View/MasterPng.png"  Height="100" Width="100" HorizontalAlignment="Right" ></Image>

        <TextBlock x:Name="DateAndTime" Text="История продаж" FontSize="20" FontWeight="Bold" Grid.Row="0" Padding="10, 10"   ></TextBlock>
        <TextBlock  x:Name="namePartners" Text="Партнёр:" Padding="10, 40"></TextBlock>
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,40,0,2" >

            <TextBlock Text="Поиск:" Grid.Row="0" VerticalAlignment="Center"  ></TextBlock>
            <TextBox x:Name="search" Grid.Row="0" Height="40" Width="200" Margin="20, 10"  TextChanged="search_TextChanged"  ></TextBox>
        </StackPanel>


        <DataGrid x:Name="HistoryTable" Grid.Row="1"></DataGrid>
        <StackPanel Grid.Row="2" Grid.Column="1"  Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left">
            <Button   Margin="10" Foreground="White" Content="Добавить" Background="#67BA80" ></Button>
            <Button   Margin="10" Foreground="White" Content="Изменить" Background="#67BA80" ></Button>
            <Button   Margin="10" Foreground="White" Content="Экспорт" Background="#67BA80"></Button>
            <!--Button   Margin="10" Foreground="White" Content="Удалить" Background="#F1404A"></Button> -->
            <Button   Margin="10" Foreground="White" Content="Назад" Background="#F1404A" Click="Button_Click"></Button>
            <TextBlock x:Name="counts" Text="Общая сумма" VerticalAlignment="Center"></TextBlock>
        </StackPanel>

    </Grid>
</Window>
