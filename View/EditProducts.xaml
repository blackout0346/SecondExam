<Window x:Class="secondExam.View.EditProducts"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:secondExam.View"
        mc:Ignorable="d"
        Title="EditProducts" Height="450" Width="800">
    <Window.Resources>

        <Style TargetType="{x:Type TextBlock}"  >
            <Setter Property="FontFamily" Value="Segoe UI" ></Setter>
            <Setter Property="FontSize" Value="15" ></Setter>
        </Style>
        <Style TargetType="{x:Type Button}">
            <Setter Property="FontFamily" Value="Segoe UI"></Setter>
            <Setter Property="Width" Value="100"></Setter>
            <Setter Property="Height" Value="50"></Setter>
        </Style>
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="FontFamily" Value="Segoe UI"></Setter>
        </Style>


    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*">
            </ColumnDefinition>
            <ColumnDefinition Width="*">
            </ColumnDefinition>

        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions >
            <RowDefinition >
            </RowDefinition>
            <RowDefinition Height="auto">
            </RowDefinition>
            <RowDefinition>
            </RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"  Orientation="Vertical">

            <TextBlock Text="Названии продукции *"></TextBlock>
            <TextBox x:Name="NameProduct"></TextBox>
            <TextBlock Text="Тип продукции *"></TextBlock>
            <ComboBox x:Name="TypeProduct">
                <TextBlock>Паркетная доска</TextBlock>
                <TextBlock>Ламинат</TextBlock>
                <TextBlock>Пробковое покрытие</TextBlock>
            </ComboBox>
            <TextBlock Text="Артикул *"></TextBlock>
            <TextBox x:Name="Article"></TextBox>
            <TextBlock Text="Минимальная стоимость *"></TextBlock>
            <TextBox x:Name="MinPrice"></TextBox>

        </StackPanel>
        <TextBlock  Grid.Column="0" Grid.ColumnSpan="2" Text="Редактирование продуктов" FontSize="20" FontWeight="Bold" Grid.Row="0" Padding="10, 10"  Background="#F4E8D3" ></TextBlock>
        <TextBlock Text="Добавление продуктов" Padding="10, 40"></TextBlock>
        <Button  Grid.Column="0"  Grid.Row="3" Foreground="White" Content="Принять" HorizontalAlignment="Center" Background="#67BA80" Click="Button_Click"  ></Button>
        <Button  Grid.Column="1"  Grid.ColumnSpan="2" Grid.Row="3" Foreground="White" Content="Отмена" HorizontalAlignment="Center" Background="#F1404A" Click="Button_Click_1"></Button>


    </Grid>
</Window>
