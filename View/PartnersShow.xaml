<Window x:Class="secondExam.View.PartnersShow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:secondExam.View"
        mc:Ignorable="d"
        Title="Партнёры" Height="450" Width="800" Background="#F4E8D3">
    <Window.Resources>

        <Style TargetType="{x:Type TextBlock}"  >
            <Setter Property="FontFamily" Value="Segoe UI" ></Setter>
            <Setter Property="FontSize" Value="15" ></Setter>
        </Style>
        <Style TargetType="{x:Type Button}">
            <Setter Property="FontFamily" Value="Segoe UI"></Setter>
            <Setter Property="Width" Value="100"> </Setter>
            <Setter Property="Height" Value="50"></Setter>
        </Style>
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="FontFamily" Value="Segoe UI"></Setter>
        </Style>


    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition>
            </ColumnDefinition>


        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions >
            <RowDefinition >
            </RowDefinition>
            <RowDefinition>
            </RowDefinition>
            <RowDefinition>
            </RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Image   Source="/View/MasterPng.png"  Height="100" Width="100" HorizontalAlignment="Left" ></Image>

            <TextBlock  Text="Мастер пол"  Margin="30"></TextBlock>
        </StackPanel>
       
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" >
            <TextBlock Text="Поиск:" Grid.Row="0" VerticalAlignment="Center"  ></TextBlock>
            <TextBox x:Name="search" Grid.Row="0" Height="40" Width="200" Margin="20, 10"  TextChanged="search_TextChanged"  ></TextBox>
        </StackPanel>

        <ListBox x:Name="displayPartner" Grid.Row="1" >
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" >
               
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Width" Value="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth}"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
        <StackPanel Grid.Row="2" Grid.Column="1"  Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left" >
            <Button   Margin="10" Foreground="White" Content="Добавить" Background="#67BA80" Click="Button_Click_2" ></Button>
            <Button   Margin="10" Foreground="White" Content="Редактировать" Background="#67BA80" Click="Button_Click_4" ></Button>
            <Button   Margin="10" Foreground="White" Content="Продукция" Background="#67BA80" Click="Button_Click"></Button>
            <Button   Margin="10" Foreground="White" Content="История продаж" Background="#67BA80" Click="Button_Click_1"></Button>
            <Button   Margin="10" Foreground="White" Content="Удалить" Background="#F1404A" Click="Button_Click_3"></Button>
            <Button   Margin="10" Foreground="White" Content="Обновить" Background="#67BA80" Click="Button_Click_5"></Button>
    
        </StackPanel>

    </Grid>
</Window>
